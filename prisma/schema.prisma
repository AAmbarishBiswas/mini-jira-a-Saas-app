generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id    String @id @default(cuid())
  email String @unique
  tasks Task[]
}

model Task {
  id        String   @id @default(cuid())
  title     String
  status    String   @default("TODO")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}